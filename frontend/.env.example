# Frontend environment — SERVER-SIDE ONLY.
# These are read by Next route handlers / server code; never exposed to the browser.
# Do NOT prefix with NEXT_PUBLIC_ — that would leak the token to the client bundle.

# Base URL of the Python API gateway (no trailing slash).
# Dev: the gateway on your PC. Prod: localhost on the Pi5 (frontend + gateway co-located).
GATEWAY_URL=http://localhost:8000

# Shared bearer token the gateway expects (server/.env API_TOKEN). Empty = gateway auth
# disabled (dev only). Never commit the real value.
GATEWAY_TOKEN=

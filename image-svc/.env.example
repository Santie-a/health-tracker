# Image service config. Copy to .env and adjust. All vars are IMAGE_SVC_-prefixed.

# Shared bearer token the gateway sends (Authorization: Bearer ...).
# Leave empty to disable auth (dev only — keep the service on LAN/VPN).
IMAGE_SVC_API_TOKEN=

# Estimator backend: "stub" (deterministic placeholder, no GPU) or "vlm".
IMAGE_SVC_BACKEND=stub

# --- vlm backend ---
# 3B fits in 12 GB at bf16; use Qwen/Qwen2.5-VL-7B-Instruct + LOAD_IN_4BIT for 7B.
IMAGE_SVC_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
# Optional local model dir (overrides MODEL_NAME / HF cache). Leave empty to use HF cache.
IMAGE_SVC_MODEL_DIR=
# auto | cuda | cpu
IMAGE_SVC_DEVICE=auto
# Load the model at startup instead of on first request.
IMAGE_SVC_PRELOAD_MODEL=false
# Load in 4-bit (needs bitsandbytes); only for 7B-class models.
IMAGE_SVC_LOAD_IN_4BIT=false

# --- versioning (recorded on every estimate) ---
IMAGE_SVC_MODEL_VERSION=stub-0
IMAGE_SVC_TABLE_VERSION=usda-subset-0.2

# --- limits ---
IMAGE_SVC_MAX_IMAGE_MB=15
# Decoded-pixel ceiling (decompression-bomb guard). 100 MP fits high-res phone photos.
IMAGE_SVC_MAX_IMAGE_PIXELS=100000000
# VLM input cap: images are downscaled to at most this many pixels before inference.
# GPU memory scales with pixel count, so a full-res phone photo (4K ≈ 8 MP) overflows VRAM;
# ~1 MP identifies foods fine. Lower if you still hit OOM, raise if you have VRAM to spare.
IMAGE_SVC_MAX_PIXELS=1000000

# --- observability ---
# DEBUG | INFO | WARNING | ERROR. Logs go to stdout (captured by Docker/systemd).
IMAGE_SVC_LOG_LEVEL=INFO

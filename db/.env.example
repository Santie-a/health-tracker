# Copy to .env and fill in. .env is gitignored — never commit real credentials.
# These are consumed both by the Postgres container (env_file) and by
# docker-compose variable substitution (DB_BIND_ADDR for the port binding).

POSTGRES_USER=health
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=health_tracker

# Interface docker publishes 5432 on.
#   127.0.0.1  -> localhost only (dev default, safest)
#   <Pi5 LAN/VPN IP> -> reachable by the server box over the LAN/VPN
#   0.0.0.0    -> all interfaces (only if behind a firewall/VPN — discouraged)
DB_BIND_ADDR=127.0.0.1

# Connection string the server's .env will use (for reference; not read here):
#   postgresql+asyncpg://health:<password>@db:5432/health_tracker
#   (host is the `db` service name in the unified stack; `localhost` only for host-run dev)

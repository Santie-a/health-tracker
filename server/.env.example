# Server (gateway) config. Copy to .env and fill in. .env is gitignored.
# Values differ per host (see DEPLOY.md) — only API_TOKEN must match image-svc.

# --- database ---
# asyncpg driver URL. In the unified stack (root docker-compose.yml) the host MUST be the
# db SERVICE NAME `db` → ...@db:5432/...  (inside a container `localhost` is the container
# itself, not the database). Use localhost only when running the server on the host against
# a db whose port is published to localhost (dev).
DATABASE_URL=postgresql+asyncpg://health:change-me@db:5432/health_tracker

# --- auth ---
# Single shared bearer token the frontend sends to the gateway. Leave empty to
# disable auth (dev only — keep the service on LAN/VPN regardless).
API_TOKEN=

# --- image-svc bridge ---
# URL of the GPU image service. localhost during dev; the PC's LAN/VPN IP in prod.
# The token sent to it is the SAME API_TOKEN above (one shared secret).
IMAGE_SVC_URL=http://localhost:8001
# Seconds to wait on the image service before falling back to manual entry.
IMAGE_SVC_TIMEOUT=30

# --- observability ---
# DEBUG | INFO | WARNING | ERROR. Logs go to stdout (captured by Docker/systemd).
LOG_LEVEL=INFO
